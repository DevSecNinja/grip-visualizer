{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start web server",
      "type": "shell",
      "command": "npm run dev -- --port 5173",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:.*http://localhost:5173/"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Open web page",
      "type": "shell",
      "command": "\"$BROWSER\" http://localhost:5173/",
      "dependsOn": "Start web server",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}
